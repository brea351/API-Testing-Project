  "item": [
    {
      "name": "Regression Tests",
      "item": [
        {
          "name": "Smoke Test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.expect(pm.response.code).to.eql(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is acceptable\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is valid JSON\", function () {\r",
                  "    pm.response.to.be.json;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"API returned product data\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.property(\"data\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://api.freeapi.app/api/v1/public/randomproducts",
              "protocol": "https",
              "host": [
                "api",
                "freeapi",
                "app"
              ],
              "path": [
                "api",
                "v1",
                "public",
                "randomproducts"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Functional Test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Validate successful response\r",
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// 2. Functional Check: Parameter Reflection\r",
                  "pm.test(\"API correctly captures 'query' parameter\", () => {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    // Validate that the server received our 'phone' query\r",
                  "    pm.expect(jsonData.args.query).to.eql(\"phone\");\r",
                  "});\r",
                  "\r",
                  "// 3. Functional Check: Limit Validation\r",
                  "pm.test(\"API correctly captures 'limit' parameter\", () => {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    // Validate that the server received our limit of 5\r",
                  "    pm.expect(jsonData.args.limit).to.eql(\"5\");\r",
                  "});\r",
                  "\r",
                  "// 4. Header Validation (Crucial for Functional QA)\r",
                  "pm.test(\"Request used correct Host header\", () => {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.headers.host).to.eql(\"postman-echo.com\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://postman-echo.com/get?query=phone&limit=5",
              "protocol": "https",
              "host": [
                "postman-echo",
                "com"
              ],
              "path": [
                "get"
              ],
              "query": [
                {
                  "key": "query",
                  "value": "phone"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Integration Test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Status Check\r",
                  "pm.test(\"Producer: Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// 2. Integration Logic: Extract and Save Data\r",
                  "pm.test(\"Integration: Data extracted for next request\", () => {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    const capturedUser = jsonData.args.username;\r",
                  "    \r",
                  "    // Save this to a variable so Request #2 can see it\r",
                  "    pm.collectionVariables.set(\"saved_username\", capturedUser);\r",
                  "    \r",
                  "    pm.expect(pm.collectionVariables.get(\"saved_username\")).to.eql(\"TosinQA\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "",
