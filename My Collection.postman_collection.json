              ],
              "path": [
                "get"
              ],
              "query": [
                {
                  "key": "username",
                  "value": "TosinQA"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Integration Test 2",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Status Check\r",
                  "pm.test(\"Consumer: Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// 2. Integration Check: Verify data was passed correctly\r",
                  "pm.test(\"Integration: Request #2 received data from Request #1\", () => {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    const receivedUser = jsonData.args.login_check;\r",
                  "    \r",
                  "    // Verify the data matches what we saved earlier\r",
                  "    pm.expect(receivedUser).to.eql(pm.collectionVariables.get(\"saved_username\"));\r",
                  "});"
